# Maintainer: mxaddict <mxaddict@kryptic.sh>
#
# Auto-generated. Source: https://github.com/kryptic-sh/gpur
# Edits made directly to a built .apk are not tracked. To change this
# APKBUILD, edit `pkg/alpine/APKBUILD.in` in the upstream repo and let
# `.github/workflows/ci.yml` rebuild on the next tag.
pkgname=gpur
pkgver={VERSION}
pkgrel=0
pkgdesc="btop-style GPU monitor TUI — NVIDIA, AMD, Apple Silicon"
url="https://github.com/kryptic-sh/gpur"
arch="x86_64"
license="MIT"
# !check  — no test suite shipped in the binary tarball.
# !strip  — binary is already stripped by the upstream release build,
#           and abuild's strip step rejects cross-built artifacts.
options="!check !strip"
source="gpur-v$pkgver-x86_64-unknown-linux-musl.tar.gz::https://github.com/kryptic-sh/gpur/releases/download/v$pkgver/gpur-v$pkgver-x86_64-unknown-linux-musl.tar.gz"

package() {
    install -Dm755 "$srcdir/gpur" "$pkgdir/usr/bin/gpur"
    install -Dm644 "$srcdir/LICENSE" "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
    install -Dm644 "$srcdir/README.md" "$pkgdir/usr/share/doc/$pkgname/README.md"
}

sha512sums="{SHA512_X86_64}  gpur-v$pkgver-x86_64-unknown-linux-musl.tar.gz"
